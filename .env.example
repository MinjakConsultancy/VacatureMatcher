# Kopieer naar .env en vul in. .env wordt nooit gecommit.
# Optioneel: alleen nodig voor IkWerk-scrape (anders automatisch Werkenbijdeoverheid)
IKWERK_EMAIL=je.rijksmail@voorbeeld.nl
IKWERK_PASSWORD=

# PostgreSQL (docker compose)
DATABASE_URL=postgresql://vacature:vacature@localhost:15432/vacature

# MinIO (docker compose)
MINIO_ENDPOINT=http://localhost:19000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ikwerk-vacatures
MINIO_REGION=us-east-1

# Optioneel: beheer-endpoints (ververs, match, cv-upload)
API_ADMIN_TOKEN=

# CV en keyword-config (CLI / defaults)
CV_PATH=examples/cv-voorbeeld.txt
KEYWORDS_CONFIG=config/keywords.example.yaml

# --- LLM (expliciete keuze via LLM_PROVIDER; geen automatische fallback) ---
# ollama            → gebruikt alleen OLLAMA_* (motivatiebrief, match-uitleg)
# openai_compatible → gebruikt alleen OPENAI_* (OpenAI, ToCode, andere /v1-API's)
LLM_PROVIDER=ollama

# Ollama (LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=600
OLLAMA_KEEP_ALIVE=10m

# OpenAI-compatible (LLM_PROVIDER=openai_compatible)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=
OPENAI_API_KEY=
OPENAI_TIMEOUT=600

# Scrape
SCRAPE_STAGING_DIR=/tmp/vacature-scrape
# auto = IkWerk als IKWERK_EMAIL+PASSWORD gezet, anders Werkenbijdeoverheid
SCRAPE_SOURCE=auto
IKWERK_PLAYWRIGHT_PROFILE=
IKWERK_MAX_PAGES=500
